---
import { getCollection } from "astro:content";
import ProjectLayout from "@/layouts/ProjectLayout.astro";
import ProjectMetaPanel from "@/components/pages/projects/ProjectDetail/MetaPanel";
import TableOfContents from "@/components/pages/projects/ProjectDetail/TableOfContents";
import ProjectNavigation from "@/components/pages/projects/ProjectDetail/ProjectNavigation";
import Background from "@/components/pages/projects/ProjectDetail/Background";
import { SystemGraph } from "@/components/common/SystemGraph";
import { getProjectLogo } from "@/utils/projectLogos";

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry, projects }, // Pass all projects as prop
    }));
}

const { entry, projects } = Astro.props;
const { Content, headings } = await entry.render();
const currentLogo = getProjectLogo(entry.slug);

// Format projects for navigation. ブランドマークがあればそれを最優先で使い、
// 無ければ既存の icon / thumbnail フォールバックに任せる。
const navProjects = [...projects].sort((a: any, b: any) =>
    new Date(b.data.meta.date).getTime() - new Date(a.data.meta.date).getTime()
).map((p: any) => {
    const logo = getProjectLogo(p.slug);
    return {
        slug: p.slug,
        title: p.data.title,
        iconUrl:
            logo?.mark ?? p.data.meta.icon?.src ?? p.data.meta.thumbnail?.src,
    };
});

// Generate relation graph based ONLY on tags associated with this project
const graphNodes: any[] = [];
const graphLinks: any[] = [];
const nodeSet = new Set<string>();

const currentProjectId = `projects-${entry.slug}`;
nodeSet.add(currentProjectId);
graphNodes.push({
    id: currentProjectId,
    name: entry.data.title,
    type: 'projects'
}); // Current node has no URL since we are already on it

const currentTags = entry.data.attributes?.stack || [];
currentTags.forEach((tech: string) => {
    // 1. Add Tag nodes
    const tagId = `tag-${tech}`;
    if (!nodeSet.has(tagId)) {
        nodeSet.add(tagId);
        graphNodes.push({ id: tagId, name: tech, type: 'tag' });
    }
    graphLinks.push({ source: currentProjectId, target: tagId });

    // 2. Add other projects with this tag
    projects.forEach((p: any) => {
        if (p.slug === entry.slug) return;
        
        const pTags = p.data.attributes?.stack || [];
        if (pTags.includes(tech)) {
            const pId = `projects-${p.slug}`;
            
            if (!nodeSet.has(pId)) {
                nodeSet.add(pId);
                graphNodes.push({
                    id: pId,
                    name: p.data.title,
                    type: 'projects',
                    url: `/projects/${p.slug}`
                });
            }
            
            // Ensure no duplicate links
            if (!graphLinks.some(l => l.source === pId && l.target === tagId)) {
                graphLinks.push({ source: pId, target: tagId });
            }
        }
    });
});
---

<ProjectLayout title={`${entry.data.title} | Portfolio`}>
    <!-- Wrapper for scrollable layout with sticky sidebars -->
    <div class="min-h-screen w-full font-sans text-gray-900 selection:bg-yellow-400 selection:text-black relative pt-[68px] sm:pt-[72px]">
        <Background client:load transition:persist="project-background" />
        
        <!-- Large Background Typography Watermark -->
        <div class="fixed top-20 left-10 text-[20vw] font-black text-gray-400/10 pointer-events-none z-0 select-none leading-none opacity-50 mixing-blend-overlay">
           {entry.data.title.substring(0, 2).toUpperCase()}
        </div>

        <!-- Project Navigation Bar (PRTS Style) -->
        <div class="sticky top-[68px] sm:top-[72px] z-50 w-full">
            <ProjectNavigation 
                projects={navProjects} 
                currentSlug={entry.slug} 
                client:load 
                transition:persist="project-navigation"
            />
        </div>

        <div class="flex flex-col lg:grid lg:grid-cols-12 relative z-10 w-full max-w-[1920px] mx-auto">

            <!-- Left Column: Specs Panel (sticky) -->
            <aside class="hidden lg:flex lg:col-span-3 flex-col self-start sticky top-[148px] sm:top-[152px] h-[calc(100svh-148px)] sm:h-[calc(100svh-152px)] overflow-y-auto">
                <div class="p-8 pb-4 shrink-0">
                    <ProjectMetaPanel
                        title={entry.data.title}
                        roles={entry.data.attributes.roles}
                        duration={entry.data.meta.duration}
                        stack={entry.data.attributes.stack}
                        projects={projects}
                        logoMark={currentLogo?.mark}
                        logoHorizontal={currentLogo?.horizontal}
                        client:load
                    />
                </div>
                
                <!-- System Graph for current project relations -->
                <div class="flex-grow min-h-[300px] bg-transparent flex flex-col relative w-full h-full p-4 pb-8">
                     <span class="font-mono text-3xs uppercase tracking-[0.2em] text-gray-500 mb-4 font-bold">Context_Graph</span>
                     <SystemGraph 
                         client:only="react" 
                         nodes={graphNodes} 
                         links={graphLinks} 
                         activeNodeId={`projects-${entry.slug}`}
                         className="flex-grow w-full h-full rounded-md shadow-sm !bg-white/50"
                     />
                </div>
            </aside>

            <!-- Center Column: Scrollable Content -->
            <main class="lg:col-span-7 w-full relative">

                <div class="p-8 lg:p-16 max-w-3xl mx-auto pb-32">
                    <!-- Hero Section -->
                    <div class="relative mb-16 group">
                        {currentLogo?.mark ? (
                            <div class="relative overflow-hidden aspect-video bg-transparent flex items-center justify-center">
                                <img
                                    src={currentLogo.vertical ?? currentLogo.mark}
                                    alt={`${entry.data.title} logo`}
                                    class="w-1/2 h-1/2 object-contain transition-transform duration-700 group-hover:scale-105"
                                />
                            </div>
                        ) : entry.data.meta.thumbnail ? (
                            <div class="relative overflow-hidden shadow-xl aspect-video bg-gray-100">
                                <img
                                    src={entry.data.meta.thumbnail.src}
                                    alt={entry.data.title}
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></div>
                                <div class="absolute bottom-4 left-4 bg-yellow-400 text-black px-3 py-1 font-mono text-xs font-bold tracking-widest uppercase">
                                    Visual_Reference_01
                                </div>
                            </div>
                        ) : null}
                    </div>

                    <!-- Main Content -->
                    <div class="prose prose-neutral max-w-none font-sans
                        prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tight
                        prose-h2:text-2xl prose-h2:border-l-4 prose-h2:border-yellow-400 prose-h2:pl-4 prose-h2:mt-16 prose-h2:mb-6
                        prose-h3:text-xl prose-h3:border-l-4 prose-h3:border-yellow-400 prose-h3:pl-3 prose-h3:mt-10
                        prose-h4:text-base prose-h4:mt-6
                        prose-p:text-gray-700 prose-p:leading-relaxed
                        prose-strong:text-black prose-strong:font-bold prose-strong:bg-yellow-100 prose-strong:px-1
                        prose-li:marker:text-yellow-500
                        prose-a:text-black prose-a:underline
                        prose-table:text-sm prose-table:font-sans
                        prose-blockquote:border-l-4 prose-blockquote:border-yellow-400 prose-blockquote:bg-yellow-50 prose-blockquote:py-1
                    ">
                        <Content />
                    </div>
                </div>
            </main>

            <!-- Right Column: Navigation Control Panel (sticky) -->
            <nav class="hidden lg:block lg:col-span-2 self-start sticky top-[148px] sm:top-[152px] h-[calc(100svh-148px)] sm:h-[calc(100svh-152px)] relative z-20">
                <TableOfContents 
                    headings={headings} 
                    projectLink={entry.data.meta.link}
                    client:load 
                    className="h-full"
                />
            </nav>

        </div>
    </div>
</ProjectLayout>

<style>
/* Utilities for scrollbar hiding if needed */
.scrollbar-hide::-webkit-scrollbar {
    display: none;
}
.scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
}
</style>
