---
import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import "../styles/home.css";
import { HomeIntro } from "../components/pages/home/HomeIntro";
import { HomeStack } from "../components/pages/home/HomeStack";
import WebGLTransition from "../components/common/WebGLTransition";
import SiteHeader from "../components/common/SiteHeader.astro";
import SiteFooter from "../components/common/SiteFooter.astro";
import { MarkdownActions } from "../components/common/MarkdownActions";
import { SmoothScroll } from "../components/common/SmoothScroll";
import { ogImagePath } from "../utils/og-path";
import { CONTACT, xUrl } from "../consts";

const description =
	"Product Engineer / Designer ポートフォリオサイト。Cloudflareスタックで個人プロダクトを出荷。";
const ogImage = new URL(ogImagePath(Astro.url.pathname), Astro.url);

const blogPostsCollection = await getCollection("blog");

// トップページ BlogSection 用: 最新3件を pubDate 降順で。
const latestBlogPosts = blogPostsCollection
	.slice()
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3)
	.map((b) => ({
		slug: b.id,
		title: b.data.title,
		description: b.data.description,
		pubDate: b.data.pubDate.toISOString(),
		thumbnail: b.data.thumbnail,
	}));

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Shogo Toyoshima",
	alternateName: "豊島 昇悟",
	url: siteUrl || Astro.url.origin,
	jobTitle: "Product Engineer",
	description:
		"Cloudflare Workers / D1 / Durable Objects / Workers AI を本番投入した個人開発SaaS『AIChatClip』のオーナー。プロダクトの企画から実装・運用までを1人で完結する Product Engineer / Designer。",
	knowsAbout: [
		"Cloudflare Workers",
		"Cloudflare D1",
		"Durable Objects",
		"Workers AI",
		"TypeScript",
		"React",
		"Hono",
		"Astro",
		"Browser Extension Development",
		"Obsidian Plugin Development",
		"UI Design",
		"Visual Identity",
	],
	sameAs: [CONTACT.github, xUrl()].filter(Boolean),
};
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Shogo Toyoshima Portfolio</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:site_name" content="Shogo Toyoshima Portfolio" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:title" content="Shogo Toyoshima Portfolio" />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:image" content={ogImage} />

		<link
			rel="alternate"
			type="text/markdown"
			title="View as Markdown"
			href="/index.md"
		/>
		<link
			rel="alternate"
			type="text/plain"
			title="LLM-friendly index"
			href="/llms.txt"
		/>
		<script
			type="application/ld+json"
			set:html={JSON.stringify(personSchema)}
		/>
		<!--
		  React マウント前に sessionStorage を読み、
		  2 回目以降の訪問ではロゴスプラッシュ (LogoIntroOverlay) を
		  完全スキップするための同期フラグ。
		  framer-motion の initial / transition.delay は最初の render で確定するため、
		  必ずレンダリング前に決定する必要がある。
		-->
		<script is:inline data-astro-rerun>
			(function () {
				var skip = false;
				try {
					var key = "prts-intro-seen";
					if (window.sessionStorage.getItem(key)) {
						skip = true;
					} else {
						window.sessionStorage.setItem(key, "1");
					}
				} catch (e) {
					skip = false;
				}
				window.__prtsSkipIntro = skip;
				// HomeStack の GSAP pinSpacer は hydrate 後に
				// 注入されるため、ブラウザ標準の scroll 復元 (mid-page reload で過去の scrollY を
				// 復元する) と layout 確定タイミングが噛み合わず、pin の start/end 計算が
				// ズレて「同じセクションが二か所に出る」破綻が起きる。アニメ主体の TOP では
				// 復元を諦めて常に先頭から見せる方が破綻しない。
				//
				// scrollRestoration='manual' だけでは、Chromium 系 + Lenis 環境で layout
				// 確定後に過去の scrollY が再適用されるケースがある (本人確認済み)。
				// そのため rAF ループで「ユーザーが操作する or 1 秒経過するまで scroll=0
				// を強制し続ける」形で復元を完全に潰す。
				if ("scrollRestoration" in window.history) {
					window.history.scrollRestoration = "manual";
				}
				try {
					window.scrollTo(0, 0);
				} catch (e) {
					/* ignore */
				}
				(function lockTop() {
					var armed = true;
					var disarm = function () {
						armed = false;
					};
					var opts = { once: true, passive: true, capture: true };
					window.addEventListener("wheel", disarm, opts);
					window.addEventListener("touchstart", disarm, opts);
					window.addEventListener(
						"keydown",
						disarm,
						{ once: true, capture: true },
					);
					window.setTimeout(disarm, 1000);
					var raf = function () {
						if (!armed) return;
						if (window.scrollY !== 0 || window.pageYOffset !== 0) {
							window.scrollTo(0, 0);
						}
						window.requestAnimationFrame(raf);
					};
					window.requestAnimationFrame(raf);
				})();
			})();
		</script>
		<ClientRouter />
	</head>
	<body class="min-h-screen overflow-x-hidden">
		<SiteHeader />
		<SmoothScroll client:only="react" />
		<!--
		  HomeIntro は client:only="react" のため SSR HTML に含まれず、
		  HomeStack (= client:load で SSR される WorksSection) のフォルダーが
		  hydrate 完了までの間、画面前面に出てしまうことがある。それらを SSR
		  段階で覆う初期オーバーレイ + BOOT_SEQUENCE ローディング UI。Tailwind の
		  JIT 抽出に依存すると初回 paint に間に合わないケースがあるので inline
		  style + var(--color-background) で確実に塗る。
		  SiteHeader (z-[100]) のすぐ下にあたる z-index:99 で、HomeStack 内の
		  あらゆる fixed/絶対配置要素より前に出す。
		  HomeIntro mount → 最低 600ms 待機 → opacity フェード (400ms) → display:none。
		-->
		<div
			id="hero-boot-overlay"
			aria-hidden="true"
			style="position:fixed;inset:0;z-index:99;background-color:var(--color-background);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;font-family:var(--font-mono,ui-monospace,SFMono-Regular,Menlo,monospace);transition:opacity 400ms ease-out;"
		>
			<div
				style="font-size:11px;letter-spacing:0.4em;color:var(--color-muted-foreground,#737373);text-transform:uppercase;display:flex;align-items:center;gap:8px;"
			>
				<span style="color:var(--color-accent,#facc15);">▸</span>
				<span>BOOT_SEQUENCE</span>
			</div>
			<div
				style="width:200px;height:2px;background-color:color-mix(in srgb,var(--color-foreground,#0a0a0a) 12%,transparent);overflow:hidden;position:relative;"
			>
				<div
					style="position:absolute;top:0;left:0;height:100%;width:0;background-color:var(--color-accent,#facc15);animation:hero-boot-fill 1200ms cubic-bezier(0.4,0,0.2,1) forwards;"
				></div>
			</div>
		</div>
		<HomeIntro client:only="react" />
		<HomeStack client:load blogPosts={latestBlogPosts} />
		<SiteFooter />
		<MarkdownActions client:load transition:persist="md-actions" />
		<WebGLTransition
			client:only="react"
			transition:persist="webgl-transition"
		/>
	</body>
</html>
