---
import BaseLayout from "@/layouts/BaseLayout.astro";

// 連絡チャネル定義（必要に応じてリンクを差し替えてください）
const channels = [
    {
        label: "Email",
        value: "tohshima115@gmail.com",
        href: "mailto:tohshima115@gmail.com",
        sub: "正式な打診・面談予約",
        primary: true,
    },
    {
        label: "X (Twitter)",
        value: "@_toyoshima",
        href: "https://x.com/",
        sub: "DM 一次接触歓迎",
    },
    {
        label: "Wantedly",
        value: "Profile",
        href: "https://www.wantedly.com/",
        sub: "スカウト・カジュアル面談",
    },
    {
        label: "YOUTRUST",
        value: "Profile",
        href: "https://youtrust.jp/",
        sub: "スカウト経由の連絡可",
    },
    {
        label: "GitHub",
        value: "@tohshima115",
        href: "https://github.com/tohshima115",
        sub: "公開可能な実験コードの一部",
    },
];
---

<BaseLayout
    title="Contact | Shogo Toyoshima"
    description="採用ご担当者・スカウトの方へ。連絡チャネル一覧と現在のステータス。"
>
    <main class="relative min-h-screen">
        <!-- Background Grid -->
        <div
            class="fixed inset-0 opacity-40 pointer-events-none z-0"
            style="background-image: linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px); background-size: 40px 40px;"
        >
        </div>

        <div
            class="relative z-10 container mx-auto px-6 md:px-12 py-24 max-w-4xl"
        >
            <!-- Breadcrumb -->
            <nav
                class="font-mono text-xs text-muted-foreground tracking-widest uppercase mb-8 flex items-center gap-2"
            >
                <a
                    href="/"
                    class="hover:text-accent transition-colors duration-200"
                    >Home</a
                >
                <span class="text-border">/</span>
                <span class="text-foreground">Contact</span>
            </nav>

            <!-- Header -->
            <header class="mb-16">
                <p
                    class="font-mono text-xs text-accent tracking-[0.3em] uppercase mb-4"
                >
                    + ESTABLISH_COMM
                </p>
                <h1
                    class="text-5xl md:text-7xl font-black mb-6 tracking-tighter leading-[0.9]"
                >
                    Contact
                </h1>
                <p class="text-base md:text-lg text-muted-foreground max-w-2xl">
                    プロダクトエンジニア / 業務改善エンジニア / Cloudflare 周辺技術での採用・カジュアル面談を歓迎します。
                </p>
            </header>

            <!-- Status -->
            <section class="mb-16">
                <div
                    class="border border-accent/40 bg-accent/5 p-6 md:p-8 grid grid-cols-1 md:grid-cols-3 gap-6"
                >
                    <div>
                        <p
                            class="font-mono text-[10px] text-accent tracking-[0.3em] uppercase mb-2"
                        >
                            STATUS
                        </p>
                        <p class="font-bold text-base">
                            転職活動中
                        </p>
                        <p class="text-xs text-muted-foreground mt-1">
                            カジュアル面談・スカウト OK
                        </p>
                    </div>
                    <div>
                        <p
                            class="font-mono text-[10px] text-accent tracking-[0.3em] uppercase mb-2"
                        >
                            AVAILABLE FROM
                        </p>
                        <p class="font-bold text-base">2026.07.01</p>
                        <p class="text-xs text-muted-foreground mt-1">
                            現職は2026年6月末で退職予定
                        </p>
                    </div>
                    <div>
                        <p
                            class="font-mono text-[10px] text-accent tracking-[0.3em] uppercase mb-2"
                        >
                            LOOKING FOR
                        </p>
                        <p class="font-bold text-base">Product Engineer</p>
                        <p class="text-xs text-muted-foreground mt-1">
                            0→1 / 業務改善 / Cloudflare 系
                        </p>
                    </div>
                </div>
            </section>

            <!-- Channels -->
            <section class="mb-16">
                <h2
                    class="text-xl md:text-2xl font-bold mb-6 border-l-4 border-accent pl-4"
                >
                    Channels
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    {
                        channels.map((c) => (
                            <a
                                href={c.href}
                                target={c.href.startsWith("http") ? "_blank" : undefined}
                                rel={c.href.startsWith("http") ? "noopener noreferrer" : undefined}
                                class={`group relative border bg-background/60 backdrop-blur-sm p-5 hover:border-accent/60 transition-colors duration-300 ${c.primary ? "border-accent/50" : "border-border"}`}
                            >
                                <div class="flex items-center justify-between">
                                    <div class="flex-1 min-w-0">
                                        <div class="font-mono text-[10px] text-muted-foreground tracking-widest uppercase mb-1.5">
                                            {c.label}
                                        </div>
                                        <div class="font-bold text-base text-foreground truncate">
                                            {c.value}
                                        </div>
                                        <div class="text-xs text-muted-foreground mt-1">
                                            {c.sub}
                                        </div>
                                    </div>
                                    <svg
                                        class="w-4 h-4 text-muted-foreground group-hover:text-accent group-hover:translate-x-1 transition-all flex-shrink-0 ml-3"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"
                                        />
                                    </svg>
                                </div>
                            </a>
                        ))
                    }
                </div>
                <p class="mt-6 text-xs text-muted-foreground font-mono tracking-wider">
                    ※ 一次接触は X DM またはメールが最速です。
                </p>
            </section>

            <!-- What I'm looking for -->
            <section class="mb-16">
                <h2
                    class="text-xl md:text-2xl font-bold mb-6 border-l-4 border-accent pl-4"
                >
                    こんな話をしたい
                </h2>
                <ul class="space-y-3 text-base text-foreground/90">
                    <li class="flex items-start gap-3">
                        <span class="text-accent font-mono mt-1.5">▸</span>
                        <span>
                            <strong>Cloudflare スタック</strong>を本番投入しているプロダクトの採用・スカウト
                        </span>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="text-accent font-mono mt-1.5">▸</span>
                        <span>
                            シード〜シリーズAの<strong>2〜3人目エンジニア</strong>枠
                        </span>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="text-accent font-mono mt-1.5">▸</span>
                        <span>
                            社内ツール・<strong>業務改善エンジニア</strong>として事業を支える役割
                        </span>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="text-accent font-mono mt-1.5">▸</span>
                        <span>
                            個人開発 AIChatClip の<strong>設計判断</strong>に関する技術ディスカッション
                        </span>
                    </li>
                </ul>
            </section>

            <!-- Footer Decor -->
            <div class="mt-20 flex items-center gap-4">
                <div class="h-px flex-1 bg-border"></div>
                <span
                    class="font-mono text-[10px] text-muted-foreground tracking-[0.3em] uppercase"
                >
                    Secure_Channel
                </span>
                <div class="h-px flex-1 bg-border"></div>
            </div>
        </div>
    </main>
</BaseLayout>
