---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
    title="Contact | Shogo Toyoshima"
    description="気軽な連絡フォーム。サイトの感想や表示崩れの報告も歓迎です。"
>
    <main class="relative min-h-screen">
        <!-- Background Grid -->
        <div
            class="fixed inset-0 opacity-40 pointer-events-none z-0"
            style="background-image: linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px); background-size: 40px 40px;"
        >
        </div>

        <div
            class="relative z-10 container mx-auto px-6 md:px-12 py-24 max-w-2xl"
        >
            <!-- Breadcrumb -->
            <nav
                class="font-mono text-xs text-muted-foreground tracking-widest uppercase mb-8 flex items-center gap-2"
            >
                <a
                    href="/"
                    class="hover:text-accent transition-colors duration-200"
                    >Home</a
                >
                <span class="text-border">/</span>
                <span class="text-foreground">Contact</span>
            </nav>

            <!-- Header -->
            <header class="mb-12">
                <p
                    class="font-mono text-xs text-accent tracking-[0.3em] uppercase mb-4"
                >
                    + SAY_HELLO
                </p>
                <h1
                    class="text-5xl md:text-7xl font-black mb-6 tracking-tighter leading-[0.9]"
                >
                    Contact
                </h1>
                <p class="text-base md:text-lg text-muted-foreground leading-relaxed">
                    記事の感想、雑談、仕事の話、なんでもどうぞ。
                    返信できるとは限りませんが、ぜんぶ読みます。
                </p>
            </header>

            <!-- Form -->
            <section class="mb-12">
                <form id="contact-form" class="space-y-5" novalidate>
                    <!-- honeypot (visually hidden) -->
                    <div class="hidden" aria-hidden="true">
                        <label
                            >Company
                            <input
                                type="text"
                                name="company"
                                autocomplete="off"
                                tabindex="-1"
                            />
                        </label>
                    </div>

                    <div>
                        <label
                            for="name"
                            class="block font-mono text-2xs text-muted-foreground tracking-widest uppercase mb-2"
                        >
                            Name <span class="text-border">(optional)</span>
                        </label>
                        <input
                            id="name"
                            name="name"
                            type="text"
                            autocomplete="name"
                            maxlength="100"
                            class="w-full bg-background/60 border border-border focus:border-accent focus:outline-none px-4 py-3 text-base transition-colors"
                        />
                    </div>

                    <div>
                        <label
                            for="email"
                            class="block font-mono text-2xs text-muted-foreground tracking-widest uppercase mb-2"
                        >
                            Email
                        </label>
                        <input
                            id="email"
                            name="email"
                            type="email"
                            required
                            autocomplete="email"
                            class="w-full bg-background/60 border border-border focus:border-accent focus:outline-none px-4 py-3 text-base transition-colors"
                        />
                    </div>

                    <div>
                        <label
                            for="message"
                            class="block font-mono text-2xs text-muted-foreground tracking-widest uppercase mb-2"
                        >
                            Message
                        </label>
                        <textarea
                            id="message"
                            name="message"
                            rows="7"
                            required
                            maxlength="5000"
                            class="w-full bg-background/60 border border-border focus:border-accent focus:outline-none px-4 py-3 text-base leading-relaxed resize-y transition-colors"
                        ></textarea>
                    </div>

                    <div class="flex items-center gap-4 pt-2">
                        <button
                            type="submit"
                            id="submit-btn"
                            class="group inline-flex items-center gap-2 px-6 py-3 bg-foreground text-background font-mono text-xs tracking-widest uppercase hover:bg-accent hover:text-accent-foreground transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                        >
                            <span data-label-idle>Send</span>
                            <span data-label-sending class="hidden"
                                >Sending...</span
                            >
                            <svg
                                class="w-3 h-3 group-hover:translate-x-1 transition-transform"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                            </svg>
                        </button>
                        <p
                            id="form-status"
                            class="font-mono text-xs"
                            aria-live="polite"
                        >
                        </p>
                    </div>
                </form>
            </section>

            <!-- Feedback Note -->
            <section
                class="mb-12 border border-border bg-background/60 backdrop-blur-sm p-5 md:p-6"
            >
                <p
                    class="font-mono text-2xs text-accent tracking-widest uppercase mb-2"
                >
                    + FEEDBACK_WELCOME
                </p>
                <p class="text-sm text-foreground/90 leading-relaxed">
                    「ここ使いにくい」「この画面、表示崩れてない？」みたいなのも大歓迎です。
                    一人で作っていると気付けないところが多いので、ひとことでも助かります。
                </p>
            </section>

            <!-- Direct mail fallback -->
            <p class="text-xs text-muted-foreground font-mono tracking-wider">
                フォームが動かないときは
                <a
                    href="mailto:tohshima115@gmail.com"
                    class="text-foreground underline hover:text-accent transition-colors"
                    >tohshima115@gmail.com</a
                > まで。
            </p>

            <!-- Footer Decor -->
            <div class="mt-20 flex items-center gap-4">
                <div class="h-px flex-1 bg-border"></div>
                <span
                    class="font-mono text-2xs text-muted-foreground tracking-[0.3em] uppercase"
                >
                    End_of_Page
                </span>
                <div class="h-px flex-1 bg-border"></div>
            </div>
        </div>
    </main>
</BaseLayout>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;
    const status = document.getElementById("form-status") as HTMLElement | null;
    const idleLabel = btn?.querySelector("[data-label-idle]") as HTMLElement | null;
    const sendingLabel = btn?.querySelector("[data-label-sending]") as HTMLElement | null;

    function setStatus(text: string, tone: "info" | "ok" | "error") {
        if (!status) return;
        status.textContent = text;
        status.classList.remove(
            "text-muted-foreground",
            "text-accent",
            "text-red-500",
        );
        if (tone === "ok") status.classList.add("text-accent");
        else if (tone === "error") status.classList.add("text-red-500");
        else status.classList.add("text-muted-foreground");
    }

    function setSending(sending: boolean) {
        if (!btn) return;
        btn.disabled = sending;
        idleLabel?.classList.toggle("hidden", sending);
        sendingLabel?.classList.toggle("hidden", !sending);
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form) return;

        const data = new FormData(form);
        const payload = {
            name: String(data.get("name") ?? ""),
            email: String(data.get("email") ?? ""),
            message: String(data.get("message") ?? ""),
            company: String(data.get("company") ?? ""), // honeypot
        };

        if (!payload.email || !payload.message) {
            setStatus("メールアドレスと本文を入力してください。", "error");
            return;
        }

        setSending(true);
        setStatus("送信中...", "info");

        try {
            const res = await fetch("/api/contact", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
            });
            const data = (await res.json()) as { ok: boolean; error?: string };
            if (res.ok && data.ok) {
                setStatus("送信しました。ありがとうございます！", "ok");
                form.reset();
            } else {
                setStatus(
                    data.error ?? "送信に失敗しました。時間をおいて再度お試しください。",
                    "error",
                );
            }
        } catch {
            setStatus("ネットワークエラーで送信できませんでした。", "error");
        } finally {
            setSending(false);
        }
    });
</script>
