---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ThumbnailPicture from "@/components/common/ThumbnailPicture.astro";
import BlogRelationGraph from "@/components/pages/blog/BlogRelationGraph.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post, posts },
    }));
}

const { post, posts } = Astro.props;
const { Content, headings } = await render(post);

// この記事のタグを軸にした関係グラフ。自分自身 + 同じタグを持つ他記事を集める
const graphNodes: any[] = [];
const graphLinks: any[] = [];
const nodeSet = new Set<string>();

const currentPostId = `blog-${post.id}`;
nodeSet.add(currentPostId);
graphNodes.push({
    id: currentPostId,
    name: post.data.title,
    type: "blog",
}); // 自分自身なので url は持たせない

const currentTags = post.data.tags || [];
currentTags.forEach((tag: string) => {
    const tagId = `tag-${tag}`;
    if (!nodeSet.has(tagId)) {
        nodeSet.add(tagId);
        graphNodes.push({ id: tagId, name: tag, type: "tag", url: `/blog?tag=${encodeURIComponent(tag)}` });
    }
    graphLinks.push({ source: currentPostId, target: tagId });

    posts.forEach((p: any) => {
        if (p.id === post.id) return;
        const pTags = p.data.tags || [];
        if (!pTags.includes(tag)) return;

        const pId = `blog-${p.id}`;
        if (!nodeSet.has(pId)) {
            nodeSet.add(pId);
            graphNodes.push({ id: pId, name: p.data.title, type: "blog", url: `/blog/${p.id}` });
        }
        if (!graphLinks.some((l) => l.source === pId && l.target === tagId)) {
            graphLinks.push({ source: pId, target: tagId });
        }
    });
});

const formattedDate = new Date(post.data.pubDate).toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
});
const isoDate = new Date(post.data.pubDate).toISOString();

// 公開日順(新しい順)での前後の記事。並び順は一覧ページと揃えている
const sortedPosts = [...posts].sort(
    (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const currentIndex = sortedPosts.findIndex((p: any) => p.id === post.id);
const newerPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const olderPost =
    currentIndex >= 0 && currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
---

<BaseLayout
    title={`${post.data.title} | Portfolio`}
    description={post.data.description}
>
    <div class="min-h-screen bg-background text-foreground">
        <div class="mx-auto w-full max-w-6xl px-6 pb-24 pt-24 md:px-8 md:pt-28">
            <header class="mb-12 md:mb-16">
                <a
                    href="/blog"
                    class="mb-8 inline-flex items-center gap-2 font-mono text-2xs uppercase tracking-[0.3em] text-muted-foreground transition-colors hover:text-accent"
                >
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Blog
                </a>

                {post.data.thumbnail && (
                    <div class="mb-8 aspect-video w-full overflow-hidden rounded-2xl border border-foreground/15 bg-foreground/[0.02]">
                        <ThumbnailPicture name={post.data.thumbnail} class="h-full w-full object-cover" />
                    </div>
                )}

                {post.data.tags && post.data.tags.length > 0 && (
                    <div class="mb-5 flex flex-wrap gap-1.5">
                        {post.data.tags.map((tag: string) => (
                            <span class="inline-flex items-center rounded-full border border-foreground/12 px-2.5 py-1 font-mono text-2xs uppercase tracking-wider text-muted-foreground">
                                {tag}
                            </span>
                        ))}
                    </div>
                )}

                <h1 class="font-sans font-black leading-tight tracking-tight text-foreground text-[clamp(1.75rem,4.5vw,2.75rem)]">
                    {post.data.title}
                </h1>

                <p class="mt-4 font-mono text-2xs uppercase tracking-[0.2em] text-muted-foreground">
                    <time datetime={isoDate}>{formattedDate}</time>
                </p>
            </header>

            <div class="flex flex-col gap-12 xl:grid xl:grid-cols-12 xl:items-start xl:gap-10">
                <!-- Left: Table of Contents -->
                <aside class="order-2 hidden xl:col-span-3 xl:order-1 xl:block xl:sticky xl:top-24">
                    <p class="ui-micro-label mb-4">Index</p>
                    {headings.length > 0 ? (
                        <nav class="space-y-1">
                            {headings.map((heading: any) => (
                                <a
                                    href={`#${heading.slug}`}
                                    class={`block py-1 transition-colors hover:text-accent ${
                                        heading.depth === 2
                                            ? "font-sans text-sm font-bold text-foreground"
                                            : "pl-4 font-sans text-xs text-muted-foreground"
                                    }`}
                                >
                                    {heading.text}
                                </a>
                            ))}
                        </nav>
                    ) : (
                        <p class="font-sans text-xs text-muted-foreground">目次はありません</p>
                    )}
                </aside>

                <!-- Center: Article Body -->
                <main class="order-1 w-full self-stretch xl:col-span-6 xl:order-2">
                    <article
                        class="prose prose-neutral max-w-none prose-sm md:prose-base prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-foreground prose-h2:text-lg md:prose-h2:text-xl prose-h2:border-l-[3px] prose-h2:border-accent prose-h2:pl-4 prose-h2:mt-10 prose-h2:mb-5 prose-h3:text-base md:prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3 prose-p:text-muted-foreground prose-p:leading-[1.8] prose-p:mb-6 prose-strong:text-foreground prose-strong:font-bold prose-a:text-accent hover:prose-a:text-accent/80 prose-a:transition-colors prose-a:underline prose-a:underline-offset-2 prose-img:rounded-xl prose-img:border prose-img:border-foreground/15 prose-code:text-accent prose-code:bg-accent/10 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-sm prose-code:font-mono prose-code:text-xs md:prose-code:text-sm prose-code:before:content-[''] prose-code:after:content-[''] prose-pre:bg-neutral-950 prose-pre:rounded-xl prose-pre:text-xs md:prose-pre:text-sm prose-blockquote:border-l-[3px] prose-blockquote:border-accent prose-blockquote:bg-accent/5 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:text-muted-foreground prose-ul:my-6 prose-li:text-muted-foreground prose-li:marker:text-accent prose-li:leading-[1.8] mb-24"
                    >
                        <Content />
                    </article>
                </main>

                <!-- Right: Relation Graph -->
                <BlogRelationGraph
                    nodes={graphNodes}
                    links={graphLinks}
                    activeNodeId={currentPostId}
                    class="order-3 h-[360px] w-full self-start xl:col-span-3 xl:sticky xl:top-24 xl:h-[380px]"
                />
            </div>

            <!-- Prev/Next: 公開日順での前後の記事 -->
            {(olderPost || newerPost) && (
                <nav aria-label="前後の記事" class="mt-16 grid gap-4 sm:grid-cols-2 md:mt-20">
                    {olderPost && (
                        <a
                            href={`/blog/${olderPost.id}`}
                            class="group flex flex-col gap-3 rounded-2xl border border-foreground/12 p-5 transition-colors hover:border-accent/50"
                        >
                            <span class="inline-flex items-center gap-1.5 font-sans text-xs text-muted-foreground">
                                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                                </svg>
                                前の記事
                            </span>
                            <span class="line-clamp-2 font-sans text-sm font-bold leading-snug text-foreground transition-colors group-hover:text-accent">
                                {olderPost.data.title}
                            </span>
                        </a>
                    )}
                    {newerPost && (
                        <a
                            href={`/blog/${newerPost.id}`}
                            class="group flex flex-col items-end gap-3 rounded-2xl border border-foreground/12 p-5 text-right transition-colors hover:border-accent/50 sm:col-start-2"
                        >
                            <span class="inline-flex items-center gap-1.5 font-sans text-xs text-muted-foreground">
                                次の記事
                                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                            </span>
                            <span class="line-clamp-2 font-sans text-sm font-bold leading-snug text-foreground transition-colors group-hover:text-accent">
                                {newerPost.data.title}
                            </span>
                        </a>
                    )}
                </nav>
            )}

            <div class="mt-10 flex justify-center md:mt-12">
                <a
                    href="/blog"
                    class="inline-flex items-center gap-2 border border-foreground/20 px-4 py-2 font-sans text-sm text-foreground transition-colors hover:border-accent hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-foreground"
                >
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    <span>ブログ一覧に戻る</span>
                </a>
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
