---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import BlogHeader from "@/components/pages/blog/BlogHeader.astro";
import BlogTagFilter from "@/components/pages/blog/BlogTagFilter.astro";
import BlogPostList from "@/components/pages/blog/BlogPostList.astro";
import BlogRelationGraph from "@/components/pages/blog/BlogRelationGraph.astro";
import type { GraphLink, GraphNode } from "@/components/common/SystemGraph";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 記事ノードとタグノードの二部グラフ
const graphNodes: GraphNode[] = [];
const graphLinks: GraphLink[] = [];
const seenTags = new Set<string>();

posts.forEach((post) => {
    const postId = `blog-${post.id}`;
    graphNodes.push({
        id: postId,
        name: post.data.title,
        type: "blog",
        url: `/blog/${post.id}`,
    });

    (post.data.tags ?? []).forEach((tag: string) => {
        const tagId = `tag-${tag}`;
        if (!seenTags.has(tagId)) {
            seenTags.add(tagId);
            graphNodes.push({
                id: tagId,
                name: tag,
                type: "tag",
                url: `/blog?tag=${encodeURIComponent(tag)}`,
            });
        }
        graphLinks.push({ source: postId, target: tagId });
    });
});
---

<BaseLayout
    title="Blog | Portfolio"
    description="Development logs and thoughts."
>
    <div class="min-h-screen bg-background text-foreground">
        <main class="mx-auto w-full max-w-5xl px-6 pb-24 md:px-8">
            <BlogHeader />
            <BlogTagFilter />

            <div class="flex flex-col gap-10 lg:flex-row lg:gap-14">
                <div class="min-w-0 flex-1">
                    <BlogPostList posts={posts} />
                </div>
                <BlogRelationGraph nodes={graphNodes} links={graphLinks} />
            </div>
        </main>
    </div>
</BaseLayout>
