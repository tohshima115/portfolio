---
import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { AboutJourney } from "@/components/pages/about/AboutJourney";

const entry = await getEntry("_pages", "about");
if (!entry) {
    throw new Error("about entry not found in _pages collection");
}
const { Content } = await render(entry);
const { title, description, headline, roleLabel } = entry.data;
const [givenName, familyName] = headline ?? ["Shogo", "Toyoshima"];
---

<BaseLayout
    title={`${title} | Shogo Toyoshima`}
    description={description}
>
    <main class="relative min-h-screen">
        <!-- Background Grid -->
        <div
            class="fixed inset-0 opacity-40 pointer-events-none z-0"
            style="background-image: linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px); background-size: 40px 40px;"
        >
        </div>

        <div
            class="relative z-10 container mx-auto px-6 md:px-12 lg:px-20 py-24 max-w-5xl"
        >
            <!-- Breadcrumb -->
            <nav
                class="font-mono text-xs text-muted-foreground tracking-widest uppercase mb-8 flex items-center gap-2"
            >
                <a
                    href="/"
                    class="hover:text-accent transition-colors duration-200"
                    >Home</a
                >
                <span class="text-border">/</span>
                <span class="text-foreground">About</span>
            </nav>

            <!-- Header -->
            <header class="mb-16">
                <p
                    class="font-mono text-xs text-accent tracking-[0.3em] uppercase mb-4"
                >
                    + USER_DATA_ARCHIVE
                </p>
                <h1
                    class="text-5xl md:text-7xl font-black mb-6 tracking-tighter leading-[0.9]"
                >
                    {givenName}<br />{familyName}
                </h1>
                {roleLabel && (
                    <div class="flex items-center gap-4">
                        <div class="h-[2px] w-12 bg-accent"></div>
                        <p
                            class="font-mono text-sm tracking-[0.25em] text-foreground font-bold uppercase"
                        >
                            {roleLabel}
                        </p>
                    </div>
                )}
            </header>

            <!-- MDX-driven content (Bio + 一貫した行動パターン intro) -->
            <section class="mb-12">
                <article
                    class="prose prose-invert max-w-3xl
                        prose-p:text-base md:prose-p:text-lg
                        prose-p:text-foreground/90 prose-p:leading-relaxed
                        prose-strong:text-foreground prose-strong:font-bold
                        prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:font-bold
                        prose-h2:border-l-4 prose-h2:border-accent prose-h2:pl-4
                        prose-h2:tracking-tight prose-h2:mb-3 prose-h2:mt-16
                        prose-ul:hidden prose-h2:[&+p]:text-muted-foreground
                        prose-h2:[&+p]:pl-5 prose-h2:[&+p]:leading-relaxed
                        prose-h2:[&+p]:mb-8"
                >
                    <Content />
                </article>
            </section>

            <!-- 経歴タイムライン + 素顔 (インライン展開) -->
            <AboutJourney client:load />

            <!-- Footer Decor -->
            <div class="mt-20 flex items-center gap-4">
                <div class="h-px flex-1 bg-border"></div>
                <span
                    class="font-mono text-2xs text-muted-foreground tracking-[0.3em] uppercase"
                >
                    End_of_Profile
                </span>
                <div class="h-px flex-1 bg-border"></div>
            </div>
        </div>
    </main>
</BaseLayout>
