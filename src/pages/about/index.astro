---
import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { AboutJourney } from "@/components/pages/about/AboutJourney";

const entry = await getEntry("_pages", "about");
if (!entry) {
    throw new Error("about entry not found in _pages collection");
}
const { Content } = await render(entry);
const { title, description, headline, roleLabel } = entry.data;
---

<BaseLayout
    title={`${title} | Shogo Toyoshima`}
    description={description}
>
    <div class="min-h-screen bg-background text-foreground">
        <main class="mx-auto w-full max-w-5xl px-6 pb-24 md:px-8">
            <!-- Header: Works/Blog と同じ breadcrumb + 中央揃え見出しの型に揃える -->
            <header class="pt-24 pb-14 text-center md:pt-28 md:pb-16">
                <nav
                    aria-label="Breadcrumb"
                    class="mb-3 flex items-center justify-center gap-2 font-mono text-2xs uppercase tracking-[0.3em] text-muted-foreground"
                >
                    <a href="/" class="transition-colors hover:text-accent">Home</a>
                    <span class="text-border">/</span>
                    <span class="text-foreground">About</span>
                </nav>
                <h1 class="font-sans font-black uppercase leading-none tracking-tight text-foreground text-[clamp(2rem,6svh,3.5rem)]">
                    About
                </h1>
            </header>

            <!-- Profile: 写真と名前を同じ重さで並べる (名前だけを巨大化させない) -->
            <section class="mb-16 flex flex-col items-center gap-6 sm:flex-row sm:items-center sm:gap-8">
                <div class="aspect-[3/4] w-40 shrink-0 overflow-hidden rounded-2xl border border-foreground/15 bg-foreground/[0.03] sm:w-48 md:w-56">
                    <picture>
                        <source srcset="/about/profile.avif" type="image/avif" />
                        <source srcset="/about/profile.webp" type="image/webp" />
                        <img
                            src="/about/profile.png"
                            alt="豊島昇悟"
                            class="h-full w-full object-cover"
                            loading="lazy"
                            decoding="async"
                        />
                    </picture>
                </div>

                <div class="text-center sm:text-left">
                    <h2 class="font-sans font-black leading-tight tracking-tight text-foreground text-3xl md:text-4xl">
                        {headline}
                    </h2>
                    {roleLabel && <p class="ui-micro-label mt-2">{roleLabel}</p>}
                </div>
            </section>

            <!-- MDX-driven content (プロフィール表 + Bio) -->
            <section class="mb-12">
                <article
                    class="prose prose-neutral max-w-3xl
                        prose-p:text-base md:prose-p:text-lg
                        prose-p:text-foreground/90 prose-p:leading-relaxed
                        prose-strong:text-foreground prose-strong:font-bold
                        prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:font-bold
                        prose-h2:border-l-4 prose-h2:border-accent prose-h2:pl-4
                        prose-h2:tracking-tight prose-h2:mb-3 prose-h2:mt-16
                        prose-ul:hidden prose-h2:[&+p]:text-muted-foreground
                        prose-h2:[&+p]:pl-5 prose-h2:[&+p]:leading-relaxed
                        prose-h2:[&+p]:mb-8"
                >
                    <Content />
                </article>
            </section>

            <!-- 経歴タイムライン + Works/Blogへの誘導 -->
            <AboutJourney client:load />
        </main>
    </div>
</BaseLayout>
