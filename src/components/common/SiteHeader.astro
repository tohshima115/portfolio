---
const navItems = [
    { href: "/", label: "Home" },
    { href: "/about", label: "About" },
    { href: "/projects", label: "Projects" },
    { href: "/blog", label: "Blog" },
    { href: "/updates", label: "Updates" },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
    if (href === "/") return pathname === "/";
    return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header
    transition:persist="site-header"
    class="site-header fixed top-0 inset-x-0 z-[100] pointer-events-none"
>
    <div class="px-4 sm:px-6 lg:px-10 pt-3 sm:pt-4">
        <!-- Main bar -->
        <div
            class="site-header__glass pointer-events-auto mx-auto max-w-[1600px] flex items-center justify-between gap-4 px-4 sm:px-6 h-14 rounded-full border border-white/30 bg-white/30 backdrop-blur-xl shadow-[0_4px_30px_rgba(0,0,0,0.06)]"
        >
            <!-- Logo -->
            <a
                href="/"
                class="flex items-center gap-2 shrink-0 group"
                aria-label="Home"
            >
                <img
                    src="/Iogo.svg"
                    alt=""
                    class="w-6 h-6 transition-opacity group-hover:opacity-75"
                    aria-hidden="true"
                />
                <span
                    class="font-sans font-black text-lg leading-none tracking-[-0.05em] text-foreground group-hover:text-accent transition-colors"
                    style="font-weight: 900;"
                >
                    TOYOSHIMA
                </span>
            </a>

            <!-- Desktop nav -->
            <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            data-active={isActive(item.href)}
                            class="site-header__link relative font-mono text-2xs tracking-[0.2em] uppercase px-3 py-2 rounded-full text-foreground/70 hover:text-foreground transition-colors data-[active=true]:text-foreground"
                        >
                            {item.label}
                        </a>
                    ))
                }
            </nav>

            <div class="flex items-center gap-2">
                <!-- Contact CTA (md+) -->
                <a
                    href="/contact"
                    data-active={isActive("/contact")}
                    class="site-header__cta hidden md:inline-flex items-center gap-2 px-4 h-9 rounded-full bg-foreground text-background font-mono text-2xs tracking-[0.25em] uppercase hover:bg-accent hover:text-accent-foreground transition-colors"
                >
                    Contact
                    <svg
                        class="w-3 h-3"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                </a>

                <!-- Hamburger (mobile) -->
                <button
                    id="site-menu-btn"
                    class="md:hidden flex flex-col justify-center items-center w-9 h-9 rounded-full border border-white/40 bg-white/20 hover:bg-white/40 transition-colors gap-[5px]"
                    aria-label="メニューを開く"
                    aria-expanded="false"
                    aria-controls="site-mobile-menu"
                >
                    <span class="menu-bar w-[18px] h-px bg-foreground origin-center transition-all duration-300"></span>
                    <span class="menu-bar w-[18px] h-px bg-foreground transition-all duration-300"></span>
                    <span class="menu-bar w-[18px] h-px bg-foreground origin-center transition-all duration-300"></span>
                </button>
            </div>
        </div>

        <!-- Mobile dropdown -->
        <div
            id="site-mobile-menu"
            class="site-header__glass site-mobile-menu pointer-events-auto mx-auto max-w-[1600px] mt-2 rounded-2xl border border-white/30 bg-white/30 backdrop-blur-xl shadow-[0_4px_30px_rgba(0,0,0,0.06)] overflow-hidden"
            aria-hidden="true"
        >
            <nav class="flex flex-col p-3 gap-1" aria-label="Mobile Primary">
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            data-active={isActive(item.href)}
                            class="site-header__mobile-link font-mono text-xs tracking-[0.2em] uppercase px-4 py-3 rounded-xl text-foreground/70 hover:text-foreground hover:bg-white/30 transition-colors data-[active=true]:text-foreground data-[active=true]:bg-white/20"
                        >
                            {item.label}
                        </a>
                    ))
                }
                <a
                    href="/contact"
                    class="mt-2 flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-foreground text-background font-mono text-xs tracking-[0.25em] uppercase hover:bg-accent hover:text-accent-foreground transition-colors"
                >
                    Contact
                    <svg
                        class="w-3 h-3"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                </a>
            </nav>
        </div>
    </div>
</header>

<script>
    function initMobileMenu() {
        const btn = document.getElementById("site-menu-btn");
        const menu = document.getElementById("site-mobile-menu");
        if (!btn || !menu) return;

        const bars = btn.querySelectorAll<HTMLElement>(".menu-bar");
        let open = false;

        function setOpen(next: boolean) {
            open = next;
            btn!.setAttribute("aria-expanded", String(open));
            menu!.setAttribute("aria-hidden", String(!open));
            menu!.classList.toggle("menu-open", open);

            // Animate hamburger → ✕
            if (open) {
                bars[0].style.transform = "translateY(6px) rotate(45deg)";
                bars[1].style.opacity = "0";
                bars[2].style.transform = "translateY(-6px) rotate(-45deg)";
            } else {
                bars[0].style.transform = "";
                bars[1].style.opacity = "";
                bars[2].style.transform = "";
            }
        }

        btn.addEventListener("click", () => setOpen(!open));

        // Close when a link is clicked
        menu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => setOpen(false));
        });

        // Close on outside click
        document.addEventListener("click", (e) => {
            if (open && !btn!.contains(e.target as Node) && !menu!.contains(e.target as Node)) {
                setOpen(false);
            }
        });
    }

    // Astro View Transitions 対応
    initMobileMenu();
    document.addEventListener("astro:page-load", initMobileMenu);
</script>

<style>
    /* Active indicator dot for desktop nav */
    .site-header__link[data-active="true"]::after {
        content: "";
        position: absolute;
        left: 50%;
        bottom: 4px;
        width: 4px;
        height: 4px;
        background: var(--color-accent);
        border-radius: 9999px;
        transform: translateX(-50%);
    }

    /* Mobile menu collapse/expand */
    .site-mobile-menu {
        display: grid;
        grid-template-rows: 0fr;
        opacity: 0;
        transition:
            grid-template-rows 0.25s ease,
            opacity 0.25s ease;
    }
    .site-mobile-menu > nav {
        overflow: hidden;
    }
    .site-mobile-menu.menu-open {
        grid-template-rows: 1fr;
        opacity: 1;
    }

    /* Dark background contexts */
    :global(body.bg-neutral-950) .site-header__glass,
    :global(.dark) .site-header__glass {
        background-color: oklch(0.22 0.005 100 / 0.45);
        border-color: oklch(1 0 0 / 0.12);
        color: var(--color-background);
    }
    :global(body.bg-neutral-950) .site-header__glass a,
    :global(.dark) .site-header__glass a {
        color: oklch(1 0 0 / 0.85);
    }
    :global(body.bg-neutral-950) .site-header__cta,
    :global(.dark) .site-header__cta {
        background-color: var(--color-background);
        color: var(--color-foreground);
    }
    :global(body.bg-neutral-950) #site-menu-btn .menu-bar,
    :global(.dark) #site-menu-btn .menu-bar {
        background-color: oklch(1 0 0 / 0.85);
    }
</style>
