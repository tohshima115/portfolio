---
/**
 * data-zoom-scope 配下の <img> をクリックで全画面拡大表示するライトボックス。
 * ページに1つ配置すればスコープ内の画像すべてに効く。
 */
---

<div
    id="lightbox"
    class="fixed inset-0 z-100 hidden items-center justify-center bg-background/95 backdrop-blur-sm p-4 md:p-10 cursor-zoom-out"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
>
    <img id="lightbox-img" src="" alt="" class="max-h-full max-w-full object-contain rounded-lg md:rounded-xl shadow-2xl cursor-default" />
    <button
        type="button"
        id="lightbox-close"
        aria-label="閉じる"
        class="absolute top-4 right-4 md:top-6 md:right-6 text-foreground/70 hover:text-foreground font-mono text-2xs uppercase tracking-[0.2em] border border-foreground/20 hover:border-foreground/50 px-3 py-1.5 transition-colors"
    >
        close
    </button>
</div>

<script>
    function initLightbox() {
        const overlay = document.getElementById("lightbox");
        const img = document.getElementById("lightbox-img") as HTMLImageElement | null;
        const closeBtn = document.getElementById("lightbox-close");
        if (!overlay || !img) return;

        const open = (src: string, alt: string) => {
            img.src = src;
            img.alt = alt;
            overlay.classList.remove("hidden");
            overlay.classList.add("flex");
            overlay.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
        };

        const close = () => {
            overlay.classList.add("hidden");
            overlay.classList.remove("flex");
            overlay.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
        };

        document.querySelectorAll<HTMLImageElement>("[data-zoom-scope] img").forEach((el) => {
            el.classList.add("cursor-zoom-in");
            el.addEventListener("click", () => open(el.currentSrc || el.src, el.alt));
        });

        overlay.addEventListener("click", (e) => {
            if (e.target === overlay) close();
        });
        closeBtn?.addEventListener("click", close);
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") close();
        });
    }

    document.addEventListener("astro:page-load", initLightbox);
</script>
