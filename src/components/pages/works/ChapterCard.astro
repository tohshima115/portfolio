---
import { chapterSlugOf, kindMeta, projectSlugOf, type ProjectEntry } from "@/utils/works";

interface Props {
    chapter: ProjectEntry;
}

const { chapter } = Astro.props;
const ch = chapter.data.chapter!;
const kind = kindMeta(ch.kind);
const href = `/works/${projectSlugOf(chapter)}/${chapterSlugOf(chapter)}`;
---

<!-- 成果物マップの1枚。問いと結論だけをカードに出し、深掘りは章ページへ -->
<a
    href={href}
    class="group relative flex flex-col gap-4 rounded-2xl border border-foreground/15 bg-white/50 p-6 md:p-7 transition-colors duration-300 hover:border-accent"
>
    <div class="flex items-center gap-2.5">
        <span class="ui-tag-tech">{kind.en}</span>
        <span class="font-mono text-3xs uppercase tracking-[0.25em] text-muted-foreground">
            {kind.label}
        </span>
        <span aria-hidden="true" class="h-px flex-1 bg-foreground/10"></span>
    </div>

    <div class="flex flex-col gap-2">
        <p class="font-mono text-2xs md:text-xs tracking-[0.15em] text-muted-foreground leading-relaxed">
            <span class="text-accent font-bold">Q.</span>
            <span class="ml-1.5">{ch.question}</span>
        </p>
        <p class="font-sans font-bold text-foreground text-base md:text-lg leading-snug tracking-tight">
            {ch.answer}
        </p>
    </div>

    <div class="mt-auto flex items-center gap-2 pt-1 font-mono text-2xs uppercase tracking-[0.3em] text-muted-foreground transition-colors duration-300 group-hover:text-accent">
        <span>Read</span>
        <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
    </div>
</a>
