---
import { ROLES } from "@/consts";
import { getProjectLogo } from "@/utils/projectLogos";

export interface Props {
    project: any;
    index: number;
}

const { project, index } = Astro.props;
const logo = getProjectLogo(project.slug);
const delay = index * 0.08;

function getRoleLabel(value: string): string {
    const role = ROLES.find((r) => r.value === value);
    return role ? role.label : value;
}
---

<a
    href={`/works/${project.slug}`}
    class="group project-card flex flex-col gap-5 py-8 px-1 cursor-pointer"
    id={`project-card-${project.slug}`}
    data-tags={JSON.stringify(
        project.data.attributes.stack.map((t: string) => t.toLowerCase()),
    )}
    style={`--delay: ${delay}s;`}
>
    <!-- Logo -->
    <div class="card-logo-wrap">
        <div class="w-[72px] h-[72px] rounded-2xl overflow-hidden shadow-md transition-all duration-400 ease-out group-hover:shadow-xl group-hover:scale-[1.05] group-hover:-translate-y-0.5">
            {logo?.mark ? (
                <img
                    src={logo.mark}
                    alt={project.data.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                />
            ) : (
                <!-- Fallback: gradient initials -->
                <div class="w-full h-full bg-gradient-to-br from-accent/70 to-accent flex items-center justify-center">
                    <span class="text-white font-black text-2xl tracking-tight">
                        {project.data.title.charAt(0)}
                    </span>
                </div>
            )}
        </div>
    </div>

    <!-- Title + Duration -->
    <div class="flex flex-col gap-1.5">
        <h2 class="text-base font-bold leading-snug tracking-tight group-hover:text-accent transition-colors duration-300">
            {project.data.title}
        </h2>
        <span class="font-mono text-[11px] text-muted-foreground tracking-wide">
            {project.data.meta.duration}
        </span>
    </div>

    <!-- Roles -->
    <div class="flex flex-wrap gap-1.5">
        {project.data.attributes.roles.map((role: string) => (
            <span class="ui-tag-role group-hover:border-accent/30 transition-colors duration-300">
                {getRoleLabel(role)}
            </span>
        ))}
    </div>

    <!-- Stack -->
    <div class="flex flex-wrap gap-1.5">
        {project.data.attributes.stack.map((tech: string) => (
            <span class="inline-flex items-center px-2 py-0.5 text-[10px] font-mono tracking-wide uppercase text-accent/70 bg-accent/8 border border-accent/15">
                {tech}
            </span>
        ))}
    </div>

    <!-- View indicator -->
    <div class="flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-all duration-300 -translate-x-1 group-hover:translate-x-0 mt-auto pt-1">
        <span class="font-mono text-[10px] text-accent tracking-[0.2em] uppercase">View</span>
        <svg class="w-3 h-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
        </svg>
    </div>

    <!-- Bottom separator -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-border/60"></div>
</a>

<style>
    .project-card {
        position: relative;
        animation: cardFadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
        animation-delay: var(--delay, 0s);
    }

    .card-logo-wrap {
        animation: logoPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        animation-delay: calc(var(--delay, 0s) + 0.1s);
    }

    @keyframes cardFadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes logoPop {
        from {
            opacity: 0;
            transform: scale(0.78);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>
