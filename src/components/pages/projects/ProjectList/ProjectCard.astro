---
import { ROLES } from "@/consts";

export interface Props {
    project: any;
    index: number;
}

const { project, index } = Astro.props;
const baseDelay = index * 0.15 + 0.1;

// Helper to get role label from value
function getRoleLabel(value: string): string {
    const role = ROLES.find((r) => r.value === value);
    return role ? role.label : value;
}
---

<a
    href={`/projects/${project.slug}`}
    class="group relative bg-background/80 backdrop-blur-sm border border-border hover:border-accent/40 shadow-sm transition-all duration-500 overflow-hidden project-card flex flex-col h-full z-10"
    id={`project-card-${project.slug}`}
    data-tags={JSON.stringify(
        project.data.attributes.stack.map((t: string) => t.toLowerCase()),
    )}
    style={`--delay: ${baseDelay}s;`}
>
    <!-- Wipes Container (3 layers of masks) -->
    <div class="absolute inset-0 z-50 pointer-events-none">
        <!-- Layer 1: Bottom Dark Grey Wipe (Final mask before content) -->
        <div
            class="absolute inset-0 bg-[#3a3f4a] dark:bg-zinc-800 animate-panel-wipe-layer-1 z-10"
        >
        </div>

        <!-- Layer 2: Middle Primary Color Wipe -->
        <div class="absolute inset-0 bg-accent animate-panel-wipe-layer-2 z-20">
        </div>

        <!-- Fixed Decorations on Top of Layer 1 & 2 -->
        <div
            class="absolute inset-0 flex items-center justify-center animate-logo-wipe z-30"
        >
            <div
                class="absolute inset-0 overflow-hidden pointer-events-none flex items-center justify-end opacity-[0.07] text-white mix-blend-overlay"
            >
                <svg
                    class="w-64 h-64 -translate-y-8 translate-x-12 rotate-[15deg] scale-[1.5]"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path
                        d="M9 20H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H20a2 2 0 0 1 2 2v5"
                    ></path>
                    <circle cx="13" cy="12" r="2"></circle>
                    <path d="M18 19c-2.8 0-5-2.2-5-5v8"></path>
                    <circle cx="20" cy="19" r="2"></circle>
                </svg>
            </div>
            <div class="flex flex-col items-center justify-center">
                <svg
                    viewBox="40 40 168 168"
                    class="w-14 h-14 md:w-16 md:h-16 mb-4 fill-white"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <rect x="40" y="40" width="40" height="40"></rect>
                    <rect x="104" y="40" width="40" height="168"></rect>
                    <rect x="168" y="40" width="40" height="40"></rect>
                    <path d="M72,112v24h-24v-24h24M80,104h-40v40h40v-40h0Z"
                    ></path>
                    <path d="M200,112v24h-24v-24h24M208,104h-40v40h40v-40h0Z"
                    ></path>
                    <path d="M72,176v24h-24v-24h24M80,168h-40v40h40v-40h0Z"
                    ></path>
                    <path d="M200,176v24h-24v-24h24M208,168h-40v40h40v-40h0Z"
                    ></path>
                </svg>
                <span
                    class="font-mono text-[11px] sm:text-xs font-bold tracking-[0.3em] text-white uppercase ml-1 drop-shadow-sm"
                >
                    Toyoshima
                </span>
            </div>
        </div>

        <!-- Layer 3: Top Light Grey Wipe (Initial visible layer, covers everything) -->
        <div class="absolute inset-0 bg-muted animate-panel-wipe-layer-3 z-40">
        </div>
    </div>

    <!-- Index Number -->
    <div
        class="absolute top-4 right-4 z-20 font-mono text-xs text-muted-foreground group-hover:text-accent transition-colors duration-300 animate-content-fade"
    >
        {String(index + 1).padStart(2, "0")}
    </div>

    <!-- Thumbnail -->
    <div class="relative aspect-video bg-muted overflow-hidden">
        <div class="absolute inset-0 animate-image-reveal">
            {
                project.data.meta.thumbnail && (
                    <img
                        src={project.data.meta.thumbnail.src}
                        alt={project.data.title}
                        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                        loading="lazy"
                    />
                )
            }
        </div>
        <!-- Gradient Overlay -->
        <div
            class="absolute inset-0 bg-gradient-to-t from-foreground/60 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-500 z-10"
        >
        </div>

        <!-- Hover Indicator -->
        <div
            class="absolute bottom-3 right-3 flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0 z-20"
        >
            <span
                class="font-mono text-[10px] text-accent tracking-widest uppercase drop-shadow-md"
                >View</span
            >
            <svg
                class="w-3.5 h-3.5 text-accent drop-shadow-md"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"></path>
            </svg>
        </div>
    </div>

    <!-- Card Content -->
    <div
        class="p-5 space-y-4 animate-content-fade flex-1 flex flex-col z-10 relative bg-background/50"
    >
        <!-- Title -->
        <h2
            class="text-lg font-bold tracking-tight leading-snug group-hover:text-accent transition-colors duration-300"
        >
            {project.data.title}
        </h2>

        <!-- Meta Info: Duration -->
        <div
            class="flex items-center gap-2 font-mono text-[11px] text-muted-foreground"
        >
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent/60"
            ></span>
            <span>{project.data.meta.duration}</span>
        </div>

        <!-- Roles Tags -->
        <div class="flex flex-wrap gap-1.5">
            {
                project.data.attributes.roles.map((role: string) => (
                    <span class="inline-block px-2 py-0.5 text-[10px] font-mono tracking-wider uppercase text-muted-foreground bg-muted/40 border border-border group-hover:border-accent/30 transition-colors duration-300">
                        {getRoleLabel(role)}
                    </span>
                ))
            }
        </div>

        <div class="flex-1"></div>

        <!-- Tech Stack -->
        <div class="pt-3 border-t border-border flex flex-wrap gap-2">
            {
                project.data.attributes.stack.map((tech: string) => (
                    <span class="inline-block px-2 py-0.5 text-[10px] font-mono tracking-wide text-accent bg-accent/10 border border-accent/20">
                        {tech}
                    </span>
                ))
            }
        </div>
    </div>

    <!-- Bottom Accent Line (appears on hover) -->
    <div
        class="absolute bottom-0 left-0 right-0 h-0.5 bg-accent scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left z-20"
    >
    </div>
</a>

<style>
    .animate-panel-wipe-layer-3 {
        animation: wipeUp 0.5s cubic-bezier(0.76, 0, 0.24, 1) both;
        animation-delay: calc(var(--delay) + 0.1s);
    }
    .animate-panel-wipe-layer-2 {
        animation: wipeUp 0.5s cubic-bezier(0.76, 0, 0.24, 1) both;
        animation-delay: calc(var(--delay) + 0.4s);
    }
    .animate-panel-wipe-layer-1 {
        animation: wipeUp 0.5s cubic-bezier(0.76, 0, 0.24, 1) both;
        animation-delay: calc(var(--delay) + 0.7s);
    }
    .animate-logo-wipe {
        animation: logoWipe 0.5s cubic-bezier(0.76, 0, 0.24, 1) both;
        animation-delay: calc(var(--delay) + 0.7s);
    }
    .animate-content-fade {
        animation: fadeFloatUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
        animation-delay: calc(var(--delay) + 1.1s);
    }
    .animate-image-reveal {
        animation: imageReveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
        animation-delay: calc(var(--delay) + 0.7s);
    }

    @keyframes wipeUp {
        0% {
            transform: translateY(0);
        }
        100% {
            transform: translateY(-101%);
        }
    }
    @keyframes logoWipe {
        0% {
            clip-path: inset(0 0 0% 0);
        }
        100% {
            clip-path: inset(0 0 101% 0);
        }
    }
    @keyframes fadeFloatUp {
        0% {
            opacity: 0;
            transform: translateY(15px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @keyframes imageReveal {
        0% {
            opacity: 0;
            transform: scale(1.05);
        }
        100% {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>
