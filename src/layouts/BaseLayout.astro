---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import WebGLTransition from "../components/common/WebGLTransition";
import SiteHeader from "../components/common/SiteHeader.astro";
import { MarkdownActions } from "../components/common/MarkdownActions";
import { ogImagePath } from "../utils/og-path";

interface Props {
    title: string;
    description?: string;
    /** 既定ではページごとに生成される OGP 画像 (/og/**.png) を使う */
    image?: string;
}

const {
    title,
    description = "Shogo Toyoshima Portfolio — Product Engineer / Designer. Cloudflare スタックで個人プロダクトを出荷している26歳。",
    image = ogImagePath(Astro.url.pathname),
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";

const trimmedPath = Astro.url.pathname.replace(/\/+$/, "");
const mdHref = trimmedPath === "" ? "/index.md" : `${trimmedPath}.md`;
const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Shogo Toyoshima",
    alternateName: "豊島 昇悟",
    url: siteUrl || Astro.url.origin,
    jobTitle: "Product Engineer",
    description:
        "Cloudflare Workers / D1 / Durable Objects / Workers AI を本番投入した個人開発SaaS『AIChatClip』のオーナー。プロダクトの企画から実装・運用までを1人で完結する Product Engineer / Designer。",
    knowsAbout: [
        "Cloudflare Workers",
        "Cloudflare D1",
        "Durable Objects",
        "Workers AI",
        "TypeScript",
        "React",
        "Hono",
        "Astro",
        "Browser Extension Development",
        "Obsidian Plugin Development",
        "UI Design",
        "Visual Identity",
    ],
    // X のハンドルが決まったら "https://x.com/{handle}" を足す。
    // プレースホルダの URL を載せると構造化データとして不正になるので置かない。
    sameAs: ["https://github.com/tohshima115"],
};
---

<!DOCTYPE html>
<html lang="ja" class="scroll-smooth bg-background text-foreground">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/Iogo.svg" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <meta name="description" content={description} />

        <!-- Open Graph -->
        <meta property="og:site_name" content="Shogo Toyoshima Portfolio" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(image, Astro.url)} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:image" content={new URL(image, Astro.url)} />

        <link
            rel="alternate"
            type="application/rss+xml"
            title="Portfolio Updates (RSS)"
            href="/rss.xml"
        />
        <link
            rel="alternate"
            type="text/markdown"
            title="View as Markdown"
            href={mdHref}
        />
        <link
            rel="alternate"
            type="text/plain"
            title="LLM-friendly index"
            href="/llms.txt"
        />

        <!-- Structured Data: Person Schema (SEO for name search) -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify(personSchema)}
        />

        <ClientRouter />

    </head>
    <body
        class="min-h-screen relative overflow-x-hidden selection:bg-accent selection:text-accent-foreground font-sans antialiased"
    >
        <SiteHeader />
        <slot />
        <MarkdownActions client:load transition:persist="md-actions" />
        <WebGLTransition
            client:only="react"
            transition:persist="webgl-transition"
        />
    </body>
</html>
