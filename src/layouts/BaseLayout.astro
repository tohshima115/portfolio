---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
    title: string;
    description?: string;
    image?: string;
}

const {
    title,
    description = "Shogo Toyoshima Portfolio — Product Engineer / Designer. Cloudflare スタックで個人プロダクトを出荷している26歳。",
    image = "/og-image.png",
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Shogo Toyoshima",
    alternateName: "豊島 昇悟",
    url: siteUrl || Astro.url.origin,
    jobTitle: "Product Engineer",
    description:
        "Cloudflare Workers / D1 / Durable Objects / Workers AI を本番投入した個人開発SaaS『AIChatClip』のオーナー。プロダクトの企画から実装・運用までを1人で完結する Product Engineer / Designer。",
    knowsAbout: [
        "Cloudflare Workers",
        "Cloudflare D1",
        "Durable Objects",
        "Workers AI",
        "TypeScript",
        "React",
        "Hono",
        "Astro",
        "Browser Extension Development",
        "Obsidian Plugin Development",
        "UI Design",
        "Visual Identity",
    ],
    sameAs: [
        "https://github.com/tohshima115",
        "https://x.com/",
    ],
};
---

<!DOCTYPE html>
<html lang="ja" class="scroll-smooth bg-background text-foreground">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/Iogo.svg" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <meta name="description" content={description} />

        <!-- Open Graph -->
        <meta property="og:site_name" content="Shogo Toyoshima Portfolio" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(image, Astro.url)} />
        <meta property="twitter:card" content="summary_large_image" />

        <link
            rel="alternate"
            type="application/rss+xml"
            title="Portfolio Updates (RSS)"
            href="/rss.xml"
        />

        <!-- Structured Data: Person Schema (SEO for name search) -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify(personSchema)}
        />

        <ClientRouter />

        <style is:global>
            /* Custom Scrollbar for Webkit */
            ::-webkit-scrollbar {
                width: 8px;
                height: 8px;
            }
            ::-webkit-scrollbar-track {
                background: var(--color-background);
            }
            ::-webkit-scrollbar-thumb {
                background: var(--color-muted-foreground);
                border-radius: 4px;
            }
            ::-webkit-scrollbar-thumb:hover {
                background: var(--color-accent);
            }
        </style>
    </head>
    <body
        class="min-h-screen relative overflow-x-hidden selection:bg-accent selection:text-accent-foreground font-sans antialiased"
    >
        <slot />
        <script is:inline>
            document.addEventListener("astro:before-swap", (e) => {
                if (window.location.pathname === "/") {
                    e.newDocument.documentElement.classList.add(
                        "exiting-from-top"
                    );
                }
            });
        </script>
    </body>
</html>
